# International Tax Meta Router configuration
# Copy this file to .env in the repository root or export these variables in the
# environment before running scripts.

# Local checkout of https://github.com/openaccountants/openaccountants.git
OPENACCOUNTANTS_ROOT="$HOME/.hermes/sources/openaccountants"
OPENACCOUNTANTS_REPO_URL="https://github.com/openaccountants/openaccountants.git"
OPENACCOUNTANTS_BRANCH="main"

# Context packer limits
OPENACCOUNTANTS_MAX_TOTAL_CHARS="90000"
OPENACCOUNTANTS_MAX_FILE_CHARS="18000"

# Install/update helper targets. Leave defaults for a normal single-user setup.
INTERNATIONAL_TAX_META_ROUTER_REPO_ROOT=""
HERMES_SKILL_PATH="$HOME/.hermes/skills/finance-business/international-tax-meta-router"
CLAUDE_SKILL_PATH="$HOME/.claude/skills/international-tax-meta-router"
CODEX_SKILL_PATH="$HOME/.codex/skills/international-tax-meta-router"
AGENTS_SKILL_PATH="$HOME/.agents/skills/international-tax-meta-router"

# If you maintain specialist Hermes profiles, list their skill paths separated by colons.
# Example: "$HOME/.hermes/profiles/law/skills/finance-business/international-tax-meta-router"
HERMES_PROFILE_SKILL_PATHS=""
